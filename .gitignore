*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build directories
dist/
build/
target/
.gradle/

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.Pytest_cache/
.mypy_cache/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db
```